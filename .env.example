# ── KNX tunnel ───────────────────────────────────────────────────────────────
# IP address of the KNXnet/IP router or interface
KNX_IP=192.168.1.1
# UDP port of the KNXnet/IP tunnel (default: 3671)
KNX_PORT=3671

# ── MQTT broker ───────────────────────────────────────────────────────────────
MQTT_HOST=192.168.1.10
MQTT_PORT=1883
# Leave blank if your broker has no authentication
MQTT_USER=
MQTT_PASSWORD=

# ── Topic prefix ──────────────────────────────────────────────────────────────
# Group address 9/0/1 will be published / subscribed as  knx/9/0/1
MQTT_TOPIC_PREFIX=knx

# ── Web dashboard ─────────────────────────────────────────────────────────────
WEB_PORT=3000
